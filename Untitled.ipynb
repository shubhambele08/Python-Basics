      "source": [
        "string=input()\n",
        "result=\"\"\n",
        "for char in string:\n",
        "  if 'a'<=char<='z':\n",
        "    result=chr(ord(char)-32)\n",
        "    print(result,end=\" \")\n",
        "  elif char in' ':\n",
        "    print(' ',end=\" \")\n",
        "  else:\n",
        "    result=chr(ord(char)+32)\n",
        "    print(result,end=\" \")"
      ]
